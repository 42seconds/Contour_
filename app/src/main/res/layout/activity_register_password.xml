<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/white"
        android:elevation="1dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Go back"
            android:scaleType="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Progress Bar 75% -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#EEEEEE">

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="#10B981" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reg_step3_title"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:letterSpacing="-0.02"
                android:layout_marginTop="32dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reg_step3_subtitle"
                android:textSize="16sp"
                android:textColor="#6B7280"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

            <!-- Password Input -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/edtPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_password"
                    android:textColorHint="#9CA3AF"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="48dp"
                    android:inputType="textPassword" />

                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_visibility_off"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle password visibility"
                    android:scaleType="center" />
            </FrameLayout>

            <!-- Requirements Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_requirements_card"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/password_requirements"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <!-- Requirement 1 -->
                <LinearLayout
                    android:id="@+id/reqLength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:id="@+id/iconReqLength"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_unchecked" />

                    <TextView
                        android:id="@+id/txtReqLength"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/req_length"
                        android:textSize="14sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- Requirement 2 -->
                <LinearLayout
                    android:id="@+id/reqUppercase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:id="@+id/iconReqUppercase"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_unchecked" />

                    <TextView
                        android:id="@+id/txtReqUppercase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/req_uppercase"
                        android:textSize="14sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- Requirement 3 -->
                <LinearLayout
                    android:id="@+id/reqNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iconReqNumber"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_unchecked" />

                    <TextView
                        android:id="@+id/txtReqNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/req_number"
                        android:textSize="14sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="48dp" />

            <Button
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#000000"
                android:text="@string/btn_continue"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textAllCaps="false"
                android:layout_marginBottom="16dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
